{
  "version": "1.0.0",
  "last_updated": "2026-06-17",
  "description": "Actor detection rules for identifying who bears the obligation. Ordered by specificity — more specific patterns first.",
  "rules": [
    {
      "id": "ACT-001",
      "pattern": "\\bboard of directors\\b",
      "match_type": "regex",
      "canonical_actor": "Board of Directors",
      "actor_category": "governance",
      "weight": 1.0
    },
    {
      "id": "ACT-002",
      "pattern": "\\bboard(?:'s|\\s+level)?\\s+(?:committee|sub-committee)\\b",
      "match_type": "regex",
      "canonical_actor": "Board of Directors",
      "actor_category": "governance",
      "weight": 0.9
    },
    {
