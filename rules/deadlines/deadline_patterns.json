      "urgency": "short_term",
      "duration": "15 days",
      "weight": 1.0
    },
    {
      "id": "DL-015",
      "pattern": "\\bwithin\\s+(?:thirty|30)\\s+(?:calendar\\s+|working\\s+)?days\\b",
      "match_type": "regex",
      "deadline_text": "within 30 days",
      "urgency": "short_term",
      "duration": "30 days",
      "weight": 1.0
    },
    {
