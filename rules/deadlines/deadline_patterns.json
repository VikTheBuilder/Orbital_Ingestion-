      "pattern": "\\bwithin\\s+(?:one|1)\\s+(?:working\\s+)?day\\b",
      "match_type": "regex",
      "deadline_text": "within 1 day",
      "urgency": "immediate",
      "duration": "1 day",
      "weight": 1.0
    },
    {
      "id": "DL-011",
      "pattern": "\\bwithin\\s+(?:three|3)\\s+(?:working\\s+|calendar\\s+)?days\\b",
      "match_type": "regex",
      "deadline_text": "within 3 days",
      "urgency": "immediate",
      "duration": "3 days",
      "weight": 1.0
    },
    {
      "id": "DL-012",
      "pattern": "\\bwithin\\s+(?:five|5)\\s+(?:working\\s+|calendar\\s+)?days\\b",
      "match_type": "regex",
      "deadline_text": "within 5 days",
      "urgency": "immediate",
      "duration": "5 days",
      "weight": 1.0
    },
