{
  "version": "1.0.0",
  "last_updated": "2026-06-17",
  "description": "Deadline extraction rules for RBI regulatory text. Ordered by specificity — most specific first.",
  "urgency_thresholds": {
    "immediate_days": 0,
    "short_term_days": 30,
    "medium_term_days": 90,
    "long_term_days": 365
  },
  "rules": [
    {
      "id": "DL-001",
      "pattern": "\\bwith immediate effect\\b",
      "match_type": "regex",
      "deadline_text": "with immediate effect",
      "urgency": "immediate",
      "duration": null,
      "weight": 1.0
    },
    {
      "id": "DL-002",
      "pattern": "\\bimmediately\\b",
      "match_type": "regex",
      "deadline_text": "immediately",
      "urgency": "immediate",
      "duration": null,
      "weight": 1.0
    },
    {
      "id": "DL-003",
      "pattern": "\\bforthwith\\b",
      "match_type": "regex",
      "deadline_text": "forthwith",
      "urgency": "immediate",
      "duration": null,
      "weight": 1.0
    },
    {
      "id": "DL-004",
      "pattern": "\\bat the earliest\\b",
      "match_type": "regex",
      "deadline_text": "at the earliest",
      "urgency": "immediate",
      "duration": null,
      "weight": 0.9
    },
    {
      "id": "DL-005",
      "pattern": "\\bwithout delay\\b",
      "match_type": "regex",
      "deadline_text": "without delay",
      "urgency": "immediate",
      "duration": null,
      "weight": 0.9
    },
    {
      "id": "DL-006",
      "pattern": "\\bwithin\\s+(six|6)\\s+hours\\b",
      "match_type": "regex",
      "deadline_text": "within 6 hours",
      "urgency": "immediate",
      "duration": "6 hours",
      "weight": 1.0,
      "notes": "Cyber incident initial reporting SLA"
    },
    {
      "id": "DL-007",
      "pattern": "\\bwithin\\s+(twenty.four|24)\\s+hours\\b",
      "match_type": "regex",
      "deadline_text": "within 24 hours",
      "urgency": "immediate",
      "duration": "24 hours",
      "weight": 1.0
    },
    {
      "id": "DL-008",
      "pattern": "\\bwithin\\s+(forty.eight|48)\\s+hours\\b",
      "match_type": "regex",
      "deadline_text": "within 48 hours",
      "urgency": "immediate",
      "duration": "48 hours",
      "weight": 1.0
    },
    {
      "id": "DL-009",
      "pattern": "\\bwithin\\s+(seventy.two|72)\\s+hours\\b",
      "match_type": "regex",
      "deadline_text": "within 72 hours",
      "urgency": "immediate",
      "duration": "72 hours",
      "weight": 1.0
    },
    {
