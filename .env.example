# LLM Provider
LLM_PROVIDER=ollama

# Groq API
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL_EXTRACTION=llama-3.1-8b-instant
GROQ_MODEL_GAP_ANALYSIS=llama-3.3-70b-versatile
GROQ_MODEL_EVIDENCE=llama-3.3-70b-versatile
GROQ_MODEL_CHAT=llama-3.1-8b-instant
GROQ_MODEL_CLASSIFICATION=llama-3.1-8b-instant
GROQ_MAX_TOKENS=4096
GROQ_TEMPERATURE=0.1
GROQ_TIMEOUT_SECONDS=60

# Ollama / local model
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=phi3:latest
OLLAMA_MAX_TOKENS=4096
OLLAMA_TEMPERATURE=0.1
OLLAMA_TIMEOUT_SECONDS=60

# Data paths
RAW_DATA_PATH=data/raw
EXTRACTED_DATA_PATH=data/extracted
STRUCTURED_DATA_PATH=data/structured
FINETUNE_DATA_PATH=data/finetune

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=64
MIN_OBLIGATION_CONFIDENCE=0.65
